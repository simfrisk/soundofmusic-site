{
  "rewrites": [
    { "source": "/work", "destination": "/work.html" },
    { "source": "/analog-prophet", "destination": "/analog-prophet.html" }
  ],
  "headers": [
    {
      "source": "**/*.@(jpg|jpeg|png|webp|avif|gif|svg|ico|css|js|woff|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "**/*.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
